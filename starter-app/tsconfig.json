{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2017", "DOM"],
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./out",
    "rootDir": "./",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "TeamAssetRegister/**/*"
  ],
  "exclude": [
    "node_modules",
    "out"
  ]
}
